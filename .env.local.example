# ============================================================
# 🐝 BeeSearch — Environment Configuration
# ============================================================

# --- Hermes Agent (AI Engine) ---
# 支持任何 OpenAI 兼容接口：Ollama, vLLM, Together AI, OpenRouter...
NEXT_PUBLIC_HERMES_BASE_URL=http://localhost:11434/v1
NEXT_PUBLIC_HERMES_API_KEY=ollama
NEXT_PUBLIC_HERMES_MODEL=NousResearch/Hermes-3-Llama-3.1-8B

# --- 花田信息源 API Keys ---
# (也可以在花田面板中直接配置)

# Google Search (via Serper.dev)
# SERPER_API_KEY=

# Twitter/X
# TWITTER_BEARER_TOKEN=

# GitHub (可选, 提高 rate limit)
# GITHUB_TOKEN=

# Google Scholar (via SerpAPI)
# SERPAPI_KEY=

# Jina (Web Crawler, 可选)
# JINA_API_KEY=
