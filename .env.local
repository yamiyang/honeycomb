# --- Hermes Agent (AI Engine) ---
# 使用 DeepSeek API 作为底层 LLM
NEXT_PUBLIC_HERMES_BASE_URL=https://api.deepseek.com/v1
NEXT_PUBLIC_HERMES_API_KEY=sk-c030ecd2e5d84b3eac7e179f6376a237
NEXT_PUBLIC_HERMES_MODEL=deepseek-chat

# --- 花田信息源 API Keys ---
# (也可以在花田面板中直接配置)

# Google Search (via Serper.dev) — 免费 2500次/月
# 申请: https://serper.dev/
# SERPER_API_KEY=

# Twitter/X — 使用 Cookie 认证（免费，无需 API Key）
# 获取方式: 登录 x.com → F12 → Network → 复制任意请求的 Cookie 头
# TWITTER_COOKIE=

# GitHub (可选, 提高 rate limit) — 免费
# 申请: https://github.com/settings/tokens/new
# GITHUB_TOKEN=

# Google Scholar (via SerpAPI) — 免费 100次/月
# 申请: https://serpapi.com/manage-api-key
# SERPAPI_KEY=

# YouTube Data API v3 — 免费 10000单位/天
# 申请: https://console.cloud.google.com/apis/credentials
# YOUTUBE_API_KEY=

# Jina (Web Crawler, 可选) — 免费额度
# 申请: https://jina.ai/reader/
# JINA_API_KEY=

# --- 免费搜索引擎替代方案（不需要 Serper/Google） ---

# Brave Search — 免费 2000次/月（无需信用卡）
# 申请: https://brave.com/search/api/
# BRAVE_API_KEY=

# Searx — 完全免费，无需 Key（使用公共实例）
# 可选: 自定义 Searx 实例地址（默认使用公共实例）
# SEARX_INSTANCE_URL=

# DuckDuckGo — 完全免费，无需 Key（已内置）
# RSS Feeds — 完全免费，无需 Key（已内置默认源）
